#include "compression.h"
#include "utils.h"

#include <cstdint>
#include <cstdio>
#include <thrust/device_vector.h>
#include <thrust/execution_policy.h>
#include <thrust/scan.h>

__global__ void count_frequencies(uint8_t *data_in, int data_len, int *freqs) {
  uint8_t local_freqs[256];
  constexpr int workload = 16;
  int start_idx = workload * blockDim.x * blockIdx.x + threadIdx.x;
  for (int i = 0; i < workload; i++) {
    int idx = start_idx + i * blockDim.x;
    uint8_t chr = data_in[idx];
    atomicAdd(freqs + chr, 1);
  }
}

